@article{lazarus_crack_2001,
	abstract = {Using the results presented in Part \{I\}, together with various criteria, we try to qualitatively and quantitatively explain crack front rotation and segmentation under mixed mode\${\textbackslash}textbackslashbackslash\$n\{I\}+\{III\} or I+\{II\}+\{III\} conditions. We first give a qualitatively explanation of segmentation in mode I+\{III\}, based on the energetic theory of fracture. However, a satisfactory\${\textbackslash}textbackslashbackslash\$nquantitative interpretation of this phenomenon would require knowledge of a parameter that theory is unable to predict and which is provided in experimental reports. We\${\textbackslash}textbackslashbackslash\$nthen concentrate on crack front rotation. It is shown that a suitable energetic criterion is able to quantitatively reproduce crack front "rotation rates" observed in brittle\${\textbackslash}textbackslashbackslash\$nfracture in mode I+\{III\}. In fatigue, a criterion considering the sole mode \{I\} stress intensity factor is found to be more appropriate. Finally, for fatigue in general mode I+\{II\}+\{III\}\${\textbackslash}textbackslashbackslash\$nconditions, we show that the crack front rotation rate is again satisfactorily reproduced by the same criterion as before, and also that a suitable extension of the well-known\${\textbackslash}textbackslashbackslash\$nprinciple of local symmetry allows to satisfactorily predict the mean kink angle of the crack.},
	author = {Lazarus, V{\'e}ronique and Leblond, Jean-Baptiste and Mouchrif, Salah-Eddine},
	doi = {10.1016/S0022-5096(01)00008-4},
	issn = {00225096},
	journal = {Journal of the Mechanics and Physics of Solids},
	keywords = {b, a, c, crack front rotation, crack mechanics, elastic material, energy release rate, mechanical, testing},
	number = {7},
	pages = {1421--1443},
	title = {Crack front rotation and segmentation in mixed mode {I}+{III} or {I}+{II}+{III}. {Part} {II}: {Comparison} with experiments},
	volume = {49},
	year = {2001},
	bdsk-url-1 = {https://doi.org/10.1016/S0022-5096(01)00008-4}}

