@article{fraternali_convergence_2010,
	abstract = {Free discontinuity problems arising in the variational theory for fracture mechanics are considered. A I" -convergence proof for an r-adaptive 3D finite element discretization is given in the case of a brittle material. The optimal displacement field, crack pattern and mesh geometry are obtained through a variational procedure that encompasses both mechanical and configurational forces. Possible extensions to cohesive fracture and quasi-static evolutions are discussed.},
	annote = {NULL},
