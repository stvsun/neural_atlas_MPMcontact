@article{bohorquez_computational_2008,
	abstract = {The mixture equations for non-cohesive sediment transport in turbulent free-surface flow are derived fromthe ensemble-averaged Navier-Stokes equations of the three-phases water, sediment and air. Thismodel reveals amathematical equivalence between the propagation of the sediment volumetric concentration β and the phase indicator function γ employed to capture the free surface. We take advantage of this fact to formulate a conservative, explicit Finite Volume Method (FVM): the β- and γ-equation are solved using the Multi- dimensional Universal Limiter with Explicit Solution (MULES), which limits the flux of the variables to guarantee a bounded-solution; then, the mixture mass flux is formulated as a function of these limited fluxes, and is used in a segregated pressure-based solver to calculate the velocity and pressure field - the pressure equation is formally formulated as a Schur complement. This numerical scheme was implemented in the open source software OpenFOAMR ? [34] and shows a good conservative property. In particular, thismodel is first applied to study the dam-break flow against an isolated obstacle [1, 17], and then to predict the transport of sediment in shallow water flows resulting fromdam-breaks [10, 29]. To this end, stationary laws for the settling of particles, the Fickian diffusive flux and the shear-induced self-diffusion flux are considered on the slip velocity of the sediment with respect to the water. The first scenario shows that the results obtained with two-dimensional depth-averaged equations (i.e. Saint-Venant equations) are superseded by those arising from the ensemble-averaged Navier-Stokes equations. The second benchmark depicts the capabilities of the model to account for erosion and settling processes. Moreover, the boundary between the traction carpet (or bed load layer) and the intermittently suspended sediment, which cannot be sharply defined in hyperconcentrated flows, is captured with success using a Bingham model where the particle concentration value is beyond a threshold value βm. As in the former case, models based on depth- averaged variables (e.g. generalisations of the one-dimensional Saint-Venant equations to predict morphological changes) are superseded by more sophisticated and accurate procedures valid for non-hydrostatic shallow water flows over bed of arbitrary bottom slopes (e.g. the model described herein). Finally, it should be pointed out that OpenFOAMshows a good scaling in both the HP Superdome and the Barcelona Supercomputing Center facilities used in our computations.},
	author = {Bohorquez, Patricio},
	journal = {Open Source CFD International Conference 2008},
