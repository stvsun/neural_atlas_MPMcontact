@article{lazarus_comparison_2008,
	abstract = {Whatever the external loading, a crack front in a\${\textbackslash}textbackslashbackslash\$nsolid tries to reach mode I loading conditions after propagation.\${\textbackslash}textbackslashbackslash\$nIn mode I+II, the crack kinks to annihilate mode II,\${\textbackslash}textbackslashbackslash\$nkinking angle being well predicted by the principle of local\${\textbackslash}textbackslashbackslash\$nsymmetry (PLS) or by the maximum tangential stress criterion\${\textbackslash}textbackslashbackslash\$n(MTS). In presence of mode III, the problem becomes\${\textbackslash}textbackslashbackslash\$nthree-dimensional and the proposed propagation criterion\${\textbackslash}textbackslashbackslash\$nare not yet well proved and established. In particular in three\${\textbackslash}textbackslashbackslash\$npoint bending experiments (3PB) with an initially inclined\${\textbackslash}textbackslashbackslash\$ncrack, the crack twists around the direction of propagation\${\textbackslash}textbackslashbackslash\$nto finally reach a situation of pure mode I. The aim of the\${\textbackslash}textbackslashbackslash\$npaper is to compare the propagation paths predicted by two\${\textbackslash}textbackslashbackslash\$ndifferent criteria for 3PB fatigue experiments performed on\${\textbackslash}textbackslashbackslash\$nPMMA. The first criterion developed by Schollmann et al\${\textbackslash}textbackslashbackslash\$n(2002), is a three-dimensional extension of the MTS criterion\${\textbackslash}textbackslashbackslash\$nand predicts the local angles that annihilates mode II\${\textbackslash}textbackslashbackslash\$nand III at each point of the front. The second one developed\${\textbackslash}textbackslashbackslash\$nby Lazarus et al (2001b), predicts an abrupt and then progressive\${\textbackslash}textbackslashbackslash\$ntwisting of the front to annihilate mode III. Due to\${\textbackslash}textbackslashbackslash\$npresence of sign changingmode II and almost uniformmode\${\textbackslash}textbackslashbackslash\$nIII in the experiments, both criteria give good results. However,\${\textbackslash}textbackslashbackslash\$nsince mode III is predominant over mode II in the case\${\textbackslash}textbackslashbackslash\$nunder consideration, the global criterion gives better results.\${\textbackslash}textbackslashbackslash\$nNevertheless, the local type criterion seems to be of greater\${\textbackslash}textbackslashbackslash\$nuniversality for practical engineering applications.\${\textbackslash}textbackslashbackslash\$n},
	author = {Lazarus, Veronique and Buchholz, F. G. and Fulland, M. and Wiebesiek, J.},
	doi = {10.1007/s10704-008-9307-2},
	issn = {03769429},
	journal = {International Journal of Fracture},
	keywords = {Brittle fracture, 3D crack propagation path, 3D fracture criteria, LEFM, Maximum tangential stress criterion, Mode II, Mode III},
	number = {2},
	pages = {141--151},
	title = {Comparison of predictions by mode {II} or mode {III} criteria on crack front twisting in three or four point bending experiments},
	volume = {153},
	year = {2008},
	bdsk-url-1 = {https://doi.org/10.1007/s10704-008-9307-2}}

