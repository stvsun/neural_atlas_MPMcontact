@article{habla_numerical_2011,
	abstract = {In this work a new solver is developed for the OpenFOAM{\textregistered} CFD toolbox, which handles viscoelastic two-phase flows. A derivative of the volume-of-fluid (VoF) methodology is used to describe the interface. Established constitutive equations derived from kinetic theory, such as Oldroyd-B, Giesekus, FENE-P and FENE-CR, from network theory of concentrated solutions and melts, such as linear and exponential Phan-Thien-Tanner (PTT), and from reptation theory, such as Pom-Pom and XPP models, as well as multi-mode formulations are implemented in OpenFOAM. Validation of the numerical technique is performed by comparing detailed simulation predictions to data from several experimental studies, numerical studies and analytical models found in the literature. Two well-known viscoelastic free-surface effects, namely the Weissenberg and the Die Swell effect, are simulated. Furthermore, transient and steady-state droplet flow in shear and elongational flows is examined. {\copyright} 2011.},
	author = {Habla, Florian and Marschall, Holger and Hinrichsen, Olaf and Dietsche, Laura and Jasak, Hrvoje and Favero, Jovani L.},
	doi = {10.1016/j.ces.2011.06.076},
	issn = {00092509},
	journal = {Chemical Engineering Science},
	keywords = {Viscoelasticity, OpenFOAM, Non-Newtonian fluids, Polymer processing, Rheology, VOF},
	number = {22},
	pages = {5487--5496},
	title = {Numerical simulation of viscoelastic two-phase flows using {openFOAM}{\textregistered}},
	url = {http://dx.doi.org/10.1016/j.ces.2011.06.076},
	volume = {66},
	year = {2011},
	bdsk-url-1 = {http://dx.doi.org/10.1016/j.ces.2011.06.076}}

