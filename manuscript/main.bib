@phdthesis{bohorquez_study_2008-1,
	abstract = {The flow after the rupture of a dam on an inclined plane of arbitrary\${\textbackslash}textbackslashbackslash\$nslope, and the induced transport of non-cohesive sediment, is analysed\${\textbackslash}textbackslashbackslash\$nusing the shallow-water approximation. An asymptotic (analytical)\${\textbackslash}textbackslashbackslash\$nsolution is presented for the flow hydrodynamics, and compared with\${\textbackslash}textbackslashbackslash\$nthe numerical simulation of the dam-break flood. Differences arise\${\textbackslash}textbackslashbackslash\$ndue to the appearance of hydrodynamic instabilities (hereafter called\${\textbackslash}textbackslashbackslash\$nroll-waves) in the numerical solution. These roll-waves point out\${\textbackslash}textbackslashbackslash\$nthe unstable behaviour of the dam-break wave. It is found that roll-waves\${\textbackslash}textbackslashbackslash\$nenhance the transport of suspended sediment. The limitations of this\${\textbackslash}textbackslashbackslash\$nsimple model to predict the transport of sediment in dam-break floods\${\textbackslash}textbackslashbackslash\$non steep inclines are discussed. Then, a numerical experiment is\${\textbackslash}textbackslashbackslash\$ndesigned to analyse the unstable character of the dam-break wave,\${\textbackslash}textbackslashbackslash\$nthat constitutes a non-parallel and unsteady base flow. By analysing\${\textbackslash}textbackslashbackslash\$nthe linear and non-linear numerical evolution of small perturbations,\${\textbackslash}textbackslashbackslash\$nit is possible to reveal how the nature of the ensuing flow depends\${\textbackslash}textbackslashbackslash\$nnot only on the Froude number (as it happens in the classical problem\${\textbackslash}textbackslashbackslash\$nof roll-waves over a uniform and steady flow) but also on the non-parallel\${\textbackslash}textbackslashbackslash\$nand time-varying characteristics of the background flow. Consequently,\${\textbackslash}textbackslashbackslash\$nit is also shown that these effects stabilise turbulent roll-waves\${\textbackslash}textbackslashbackslash\$nand raise the critical Froude number required to achieve an unstable\${\textbackslash}textbackslashbackslash\$nflow. This stability result differs with that obtained with a non-parallel\${\textbackslash}textbackslashbackslash\$nspatial stability analysis, pointing out the strong influence of the\${\textbackslash}textbackslashbackslash\$nbase-flow time-dependence in the stability criteria. A novel Continuum\${\textbackslash}textbackslashbackslash\$nMechanics model is presented to study the transport of sediment in\${\textbackslash}textbackslashbackslash\$na laminar/turbulent free-surface flow. The mixture equations for non-cohesive\${\textbackslash}textbackslashbackslash\$nsediment transport in turbulent free-surface flow are derived from\${\textbackslash}textbackslashbackslash\$nthe ensemble averaged Navier-Stokes equations of the three-phases\${\textbackslash}textbackslashbackslash\$n(water, sediment and air). This model avoids the limitations of traditional\${\textbackslash}textbackslashbackslash\$nshallow-water models, and is suitable to study, for instance, the\${\textbackslash}textbackslashbackslash\$ntransport of sediment in non-hydrostatic shallow-water flows over\${\textbackslash}textbackslashbackslash\$nbed of arbitrary bottom slopes. The model developed in this work\${\textbackslash}textbackslashbackslash\$nreveals a mathematical equivalence between the propagation of the\${\textbackslash}textbackslashbackslash\$nvolumetric concentration of the sediment and the phase function used\${\textbackslash}textbackslashbackslash\$nto capture the free surface. We take advantage of this fact to formulate\${\textbackslash}textbackslashbackslash\$nan explicit Finite Volume Method (FVM) with the exact conservation\${\textbackslash}textbackslashbackslash\$nproperty, that is implemented in the open source software OpenFOAM.\${\textbackslash}textbackslashbackslash\$nFinally, this model is applied to solve the problem of local scour\${\textbackslash}textbackslashbackslash\$naround a pipeline and the transport of sediment after the rupture\${\textbackslash}textbackslashbackslash\$nof a horizontal dam. It is demonstrated that one-dimensional models\${\textbackslash}textbackslashbackslash\$nbased on depth-averaged variables (e.g. generalisations of the one-dimensional\${\textbackslash}textbackslashbackslash\$nSaint-Venant equations to predict morphological changes) are superseded\${\textbackslash}textbackslashbackslash\$nby more sophisticated and accurate procedures valid for hyperconcentrated\${\textbackslash}textbackslashbackslash\$nshallow-water flows over bed of arbitrary bottom slopes (e.g. the\${\textbackslash}textbackslashbackslash\$nmodel described herein).},
	author = {Bohorquez, Patricio},
	title = {Study and {Numerical} {Simulation} of {Sediment} {Transport} in {Free}-{Surface} {Flow}},
	type = {{PhD} {Thesis}},
	year = {2008}}

