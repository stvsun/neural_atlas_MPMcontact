	issn = {0141-8610},
	journal = {Philosophical Magazine A},
	month = oct,
	number = {10},
	pages = {2457--2479},
	title = {An extended {Cahn}-{Hilliard} model for interfaces with cubic anisotropy},
	url = {http://www.tandfonline.com/doi/abs/10.1080/01418610110038420},
