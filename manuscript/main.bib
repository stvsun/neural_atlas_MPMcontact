@article{rowley_reduction_2003,
	abstract = {We present a general method for analysing and numerically solving partial differential equations with self-similar solutions. The method employs ideas from symmetry reduction in geometric mechanics, and involves separating the dynamics on the shape space (which determines the overall shape of the solution) from those on the group space (which determines the size and scale of the solution). The method is computationally tractable as well, allowing one to compute self-similar solutions by evolving a dynamical system to a steady state, in a scaled reference frame where the self-similarity has been factored out. More generally, bifurcation techniques can be used to find self-similar solutions, and determine their behaviour as parameters in the equations are varied. The method is given for an arbitrary Lie group, providing equations for the dynamics on the reduced space, for reconstructing the full dynamics and for determining the resulting scaling laws for self-similar solutions. We illustrate the technique with a numerical example, computing self-similar solutions of the Burgers equation.},
	author = {Rowley, Clarence W and Kevrekidis, Ioannis G and Marsden, Jerrold E and Lust, Kurt},
	issn = {0951-7715},
	journal = {Nonlinearity},
	number = {4},
	pages = {1257},
	title = {Reduction and reconstruction for self-similar dynamical systems},
	url = {http://stacks.iop.org/0951-7715/16/i=4/a=304},
	volume = {16},
	year = {2003},
	bdsk-url-1 = {http://stacks.iop.org/0951-7715/16/i=4/a=304}}

@article{rowley_reconstruction_2000,
	abstract = {We present a method for applying the \{Karhunen-Lo{\'e}ve\} decomposition\${\textbackslash}textbackslashbackslash\$nto systems with continuous symmetry. The techniques in this paper\${\textbackslash}textbackslashbackslash\$ncontribute to the general procedure of removing variables associated\${\textbackslash}textbackslashbackslash\$nwith the symmetry of a problem, and related ideas have been used\${\textbackslash}textbackslashbackslash\$nin previous works both to identify coherent structures in solutions\${\textbackslash}textbackslashbackslash\$nof \{PDEs,\} and to derive low-order models via Galerkin projection.\${\textbackslash}textbackslashbackslash\$nThe main result of this paper is to derive a simple and easily implementable\${\textbackslash}textbackslashbackslash\$nset of reconstruction equations which close the system of \{ODEs\}\${\textbackslash}textbackslashbackslash\$nproduced by Galerkin projection. The geometric interpretation of\${\textbackslash}textbackslashbackslash\$nthe method closely parallels techniques used in geometric phases\${\textbackslash}textbackslashbackslash\$nand reconstruction techniques in geometric mechanics. We apply the\${\textbackslash}textbackslashbackslash\$nmethod to the \{Kuramoto-Sivashinsky\} equation and are able to derive\${\textbackslash}textbackslashbackslash\$naccurate models of considerably lower dimension than are possible\${\textbackslash}textbackslashbackslash\$nwith the traditional \{Karhunen-Lo{\'e}ve\} expansion.},
	author = {Rowley, Clarence W. and Marsden, Jerrold E.},
	doi = {10.1016/S0167-2789(00)00042-7},
	issn = {01672789},
	journal = {Physica D: Nonlinear Phenomena},
	keywords = {proper orthogonal decomposition, 02, 03, 05, 11, 40, 45, 47, 70, b, dh, eve expansion, gc, j, karhunen-lo, kuramoto-sivashinsky equation, metry, pacs, reconstruction, reduction, sym-},
	month = aug,
