@article{lazzarin_generalized_2006,
	abstract = {In the presence of sharp (zero radius) V-shaped notches the notch stress intensity factors (N-SIFs) quantify the intensities of the asymptotic linear elastic stress distributions. They are proportional to the limit of the mode I or II stress components multiplied by the distance powered 1 - ??i from the notch tip, ??i being Williams' eigenvalues. When the notch tip radius is different from zero, the definition is no longer valid from a theoretical point of view and the characteristic, singular, sharp-notch field diverges from the rounded-notch solution very next to the notch. Nevertheless, N-SIFs continue to be used as parameters governing fracture if the notch root radius is sufficiently small with respect to the notch depth. Taking advantage of a recent analytical formulation able to describe stress distributions ahead of rounded V-notches, the paper gives a generalized form for the notch stress intensity factors, in which not only the opening angle but also the tip radius dimension is explicitly involved. Such parameters quantify the stress redistribution due to the root radius with respect to the sharp notch case. ?? 2005 Elsevier Ltd. All rights reserved.},
	author = {Lazzarin, P. and Filippi, S.},
	doi = {10.1016/j.ijsolstr.2005.03.007},
	issn = {00207683},
	journal = {International Journal of Solids and Structures},
	keywords = {Elasticity, Corner, Crack, Generalized stress intensity factor, Stress distributions, V-notch},
	month = may,
	number = {9},
	pages = {2461--2478},
	title = {A generalized stress intensity factor to be applied to rounded {V}-shaped notches},
	url = {http://linkinghub.elsevier.com/retrieve/pii/S0020768305001186},
	volume = {43},
	year = {2006},
	bdsk-url-1 = {http://linkinghub.elsevier.com/retrieve/pii/S0020768305001186},
	bdsk-url-2 = {https://doi.org/10.1016/j.ijsolstr.2005.03.007}}

@article{radaj_state---art_2014,
	abstract = {The stress intensity factor concept for describing the stress field at pointed crack or slit tips is well known from fracture mechanics. It has been substantially extended since Williams' basic contribution (1952) on stress fields at angular corners. One extension refers to pointed V-notches with stress intensities depending on the notch opening angle. The loading-mode-related simple notch stress intensity factors K1, K2 and K 3 are introduced. Another extension refers to rounded notches with crack shape or V-notch shape in two variants: parabolic, elliptic or hyperbolic notches ('blunt notches') on the one hand and root hole notches ('keyholes' when considering crack shapes) on the other hand. Here, the loading-mode-related generalised notch stress intensity factors K1ρ, K 2ρ and K3ρ are defined. The concepts of elastic stress intensity factor, notch stress intensity factor and generalised notch stress intensity factor are extended into the range of elastic-plastic (work-hardening) or perfectly plastic notch tip or notch root behaviour. Here, the plastic notch stress intensity factors K1p, K2p and K3p are of relevance. The elastic notch stress intensity factors are used to describe the fatigue strength of fillet-welded attachment joints. The fracture toughness of brittle materials may also be evaluated on this basis. The plastic notch stress intensity factors characterise the stress and strain field at pointed V-notch tips. A new version of the Neuber rule accounting for the influence of the notch opening angle is presented. {\copyright} 2013 Wiley Publishing Ltd.},
	author = {Radaj, D.},
	doi = {10.1111/ffe.12120},
	issn = {8756758X},
	journal = {Fatigue \& Fracture of Engineering Materials \& Structures},
	keywords = {fatigue assessment, HRR field, material law, notch stress intensity factor, welded joint},
	month = jan,
	number = {1},
	pages = {1--28},
	title = {State-of-the-art review on extended stress intensity factor concepts},
	url = {http://doi.wiley.com/10.1111/ffe.12120},
	volume = {37},
	year = {2014},
	bdsk-url-1 = {http://doi.wiley.com/10.1111/ffe.12120},
	bdsk-url-2 = {https://doi.org/10.1111/ffe.12120}}

@article{li_material-point_2015,
	abstract = {We present a validation assessment of the eigenerosion scheme applied in conjunction with the Optimal Transportation Meshfree (OTM) method. The assessment is based on the detonation-driven 304L steel spherical-cap fragmentation experiments of Campbell et al. (2007). Metrics used for purposes of validation include the velocity history of a witness point of the shell and the histogram of recovered fragment sizes. The results of the simulations are found to be in overall good agreement with the experimental measurements, especially when allowances are made for uncertainties in the characterization of the drive and material properties. The ability of the approach to predictively simulate exceedingly complex patterns of fracture and fragmentation under severe conditions of loading and material behavior is remarkable, especially in consideration of the simplicity of the fracture model and its implementation.},
	author = {Li, B. and Pandolfi, A. and Ortiz, M.},
	doi = {10.1016/j.mechmat.2014.03.008},
	issn = {01676636},
	journal = {Mechanics of Materials},
	keywords = {Ductile fracture, Explosive drive, Fragmentation, Material point failure, Optimal transportation meshfree},
	number = {PB},
	pages = {288--297},
	title = {Material-point erosion simulation of dynamic fragmentation of metals},
	volume = {80},
